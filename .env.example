# cudalotto configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Bitcoin address (required)
BTC_ADDRESS=

# Worker name (optional, default: cudalotto)
WORKER=cudalotto

# Stratum pool URL (optional, default: eusolo.ckpool.org)
POOL=stratum+tcp://eusolo.ckpool.org:3333

# Email for monitoring alerts (block found, miner crash)
ALERT_EMAIL=

# Log file path
LOGFILE=/var/log/cudalotto.log
